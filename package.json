{
  "name": "tikitoki",
  "version": "1.0.0",
  "description": "Telegram bot that downloads TikTok videos and renders slideshows to MP4",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "@grammyjs/conversations": "^2.1.1",
    "p-queue": "^9.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "telegram",
    "bot",
    "tiktok",
    "slideshow",
    "ffmpeg",
    "yt-dlp"
  ],
  "license": "MIT"
}
